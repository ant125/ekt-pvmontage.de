generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  shortText   String
  fullText    String
  coverImage  String
  images      Json
  location    String?
  year        String?
  published   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id    String @id @default(cuid())
  name  String
  role  String
  image String
}

model FirmenAnfrage {
  id          String   @id @default(cuid())
  firmName    String
  contactName String
  phone       String
  email       String
  message     String
  createdAt   DateTime @default(now())
}

model Admin {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model LegalPage {
  id        String   @id @default(cuid())
  type      String   @unique // "impressum" | "datenschutz"
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
